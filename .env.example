# Copy this file to .env.local and fill in values.
# Never commit .env.local to git.

# ─── Phase 1 ────────────────────────────────────────────────
# Contact form API endpoint (Lambda + API Gateway URL)
NEXT_PUBLIC_API_URL=https://your-api-id.execute-api.ap-south-1.amazonaws.com/prod

# Google Analytics 4 measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Maps embed API key (for Contact page map)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key

# ─── Phase 2 ────────────────────────────────────────────────
# AWS Cognito (user accounts / social login)
NEXT_PUBLIC_COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=your-cognito-client-id
NEXT_PUBLIC_COGNITO_DOMAIN=care-pk.auth.ap-south-1.amazoncognito.com

# Stripe publishable key (online donations)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<your-stripe-publishable-key>

# ─── Server-side only (never NEXT_PUBLIC_) ──────────────────
# Stripe secret key — set this in Amplify environment variables, NOT here
STRIPE_SECRET_KEY=<your-stripe-secret-key>

# SES sender address (must be verified in AWS SES)
SES_FROM_EMAIL=carejmdc22@gmail.com
